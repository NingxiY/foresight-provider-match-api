DATABASE_URL=postgresql+psycopg2://postgres:password@db:5432/foresight
SECRET_KEY=foresight-dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# http://localhost:5173 = `npm run dev` (Vite dev server)
# http://localhost      = `docker compose up` frontend service (Nginx on port 80)
CORS_ORIGINS=http://localhost:5173,http://localhost

# Baked into the frontend's built JS at image-build time (see docker-compose.yml
# frontend.build.args). For an EC2 deploy, set this to http://EC2_PUBLIC_IP:8000
# *before* running `docker compose up --build`.
VITE_API_BASE_URL=http://localhost:8000
