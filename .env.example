DATABASE_URL=postgresql://postgres:password@db:5432/foresight
SECRET_KEY=changeme-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Comma-separated list of allowed frontend origins.
# Local: Vite dev server (5173) + the Dockerized frontend served on port 80.
# EC2: add http://EC2_PUBLIC_IP and http://EC2_PUBLIC_IP:80 (see README.md).
CORS_ORIGINS=http://localhost:5173,http://localhost

# Baked into the frontend's built JS at image-build time — not a runtime var.
# Local default shown below; for EC2 set this to http://EC2_PUBLIC_IP:8000
# before running `docker compose up --build` (see README.md).
VITE_API_BASE_URL=http://localhost:8000
